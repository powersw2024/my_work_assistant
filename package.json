{
  "name": "project-management-app",
  "version": "1.0.0",
  "description": "Project Management App with Electron",
  "main": "electron/main.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "node start-dev.js",
    "start": "node server/index.js",
    "init-db": "node server/db/schema.js",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "cd web && npm run build && cd .. && electron-builder build --mac --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "archiver": "^6.0.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ipinfo": "^1.5.2",
    "multer": "^1.4.5-lts.1",
    "sqlite": "^4.2.1",
    "sqlite3": "^5.1.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.0.1",
    "wait-on": "^7.2.0"
  }
}