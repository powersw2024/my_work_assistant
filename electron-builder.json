{
  "appId": "com.projectmanagement.app",
  "productName": "Project Management App",
  "npmRebuild": false,
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "electron/**/*",
    "web/dist/**/*",
    "server/**/*",
    "start-dev.js",
    "package.json",
    "!node_modules/**/*",
    "!web/node_modules/**/*",
    "!web/src/**/*",
    "!web/package-lock.json",
    "!web/vite.config.js",
    "!*.md",
    "!*.gitignore"
  ],
  "mac": {
    "category": "public.app-category.productivity",
    "target": "dmg",
    "icon": "build/icon.icns"
  },
  "dmg": {
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ]
  }
}